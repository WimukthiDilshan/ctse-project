{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {},
  "variables": {
    "envId": "[resourceId('Microsoft.App/managedEnvironments', 'ctse-env')]"
  },
  "resources": [
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "frontend",
      "location": "southeastasia",
      "properties": {
        "managedEnvironmentId": "[variables('envId')]",
        "configuration": { "ingress": { "external": true, "targetPort": 3000 } },
        "template": { "containers": [{ "name": "frontend", "image": "wimukthidocker/frontend:mentor-v2", "env": [{"name": "FORCE_UPDATE", "value": "7"}] }] }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "student-service",
      "location": "southeastasia",
      "properties": {
        "managedEnvironmentId": "[variables('envId')]",
        "configuration": { "ingress": { "external": true, "targetPort": 5001 } },
        "template": { "containers": [{ "name": "student-service", "image": "wimukthidocker/student-service:latest", "env": [{"name": "MONGO_URI", "value": "mongodb+srv://wimukthi2010_db_user:OOamEpUlOFQ8lPWn@cluster0.awyrjzu.mongodb.net/student_db?appName=Cluster0"}, {"name": "RESULT_SERVICE_URL", "value": "http://result-service"}, {"name": "FORCE_UPDATE", "value": "6"}] }] }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "teacher-service",
      "location": "southeastasia",
      "properties": {
        "managedEnvironmentId": "[variables('envId')]",
        "configuration": { "ingress": { "external": true, "targetPort": 5002 } },
        "template": { "containers": [{ "name": "teacher-service", "image": "wimukthidocker/teacher-service:latest", "env": [{"name": "MONGO_URI", "value": "mongodb+srv://wimukthi2010_db_user:OOamEpUlOFQ8lPWn@cluster0.awyrjzu.mongodb.net/teacher_db?appName=Cluster0"}, {"name": "RESULT_SERVICE_URL", "value": "http://result-service"}, {"name": "STUDENT_SERVICE_URL", "value": "http://student-service"}, {"name": "FORCE_UPDATE", "value": "7"}] }] }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "course-service",
      "location": "southeastasia",
      "properties": {
        "managedEnvironmentId": "[variables('envId')]",
        "configuration": { "ingress": { "external": true, "targetPort": 5003 } },
        "template": { "containers": [{ "name": "course-service", "image": "wimukthidocker/course-service:latest", "env": [{"name": "MONGO_URI", "value": "mongodb+srv://wimukthi2010_db_user:OOamEpUlOFQ8lPWn@cluster0.awyrjzu.mongodb.net/course_db?appName=Cluster0"}, {"name": "FORCE_UPDATE", "value": "6"}] }] }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "result-service",
      "location": "southeastasia",
      "properties": {
        "managedEnvironmentId": "[variables('envId')]",
        "configuration": { "ingress": { "external": true, "targetPort": 5004 } },
        "template": { "containers": [{ "name": "result-service", "image": "wimukthidocker/result-service:latest", "env": [{"name": "MONGO_URI", "value": "mongodb+srv://wimukthi2010_db_user:OOamEpUlOFQ8lPWn@cluster0.awyrjzu.mongodb.net/result_db?appName=Cluster0"}, {"name": "FORCE_UPDATE", "value": "6"}] }] }
      }
    }
  ]
}
