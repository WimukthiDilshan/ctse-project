{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "studentMongoUri": {
      "type": "securestring"
    },
    "teacherMongoUri": {
      "type": "securestring"
    },
    "courseMongoUri": {
      "type": "securestring"
    },
    "resultMongoUri": {
      "type": "securestring"
    },
    "studentJwtSecret": {
      "type": "securestring"
    }
  },
  "variables": {
    "envId": "[resourceId('Microsoft.App/managedEnvironments', 'ctse-env')]"
  },
  "resources": [
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "frontend",
      "location": "southeastasia",
      "properties": {
        "managedEnvironmentId": "[variables('envId')]",
        "configuration": { "ingress": { "external": true, "targetPort": 3000 } },
        "template": { "containers": [{ "name": "frontend", "image": "wimukthidocker/frontend:mentor-v2", "env": [{"name": "FORCE_UPDATE", "value": "7"}] }] }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "student-service",
      "location": "southeastasia",
      "properties": {
        "managedEnvironmentId": "[variables('envId')]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 5001
          },
          "secrets": [
            {
              "name": "student-mongo-uri",
              "value": "[parameters('studentMongoUri')]"
            },
            {
              "name": "student-jwt-secret",
              "value": "[parameters('studentJwtSecret')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "student-service",
              "image": "wimukthidocker/student-service:latest",
              "env": [
                {
                  "name": "MONGO_URI",
                  "secretRef": "student-mongo-uri"
                },
                {
                  "name": "JWT_SECRET",
                  "secretRef": "student-jwt-secret"
                },
                {
                  "name": "RESULT_SERVICE_URL",
                  "value": "http://result-service"
                },
                {
                  "name": "FORCE_UPDATE",
                  "value": "6"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "teacher-service",
      "location": "southeastasia",
      "properties": {
        "managedEnvironmentId": "[variables('envId')]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 5002
          },
          "secrets": [
            {
              "name": "teacher-mongo-uri",
              "value": "[parameters('teacherMongoUri')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "teacher-service",
              "image": "wimukthidocker/teacher-service:latest",
              "env": [
                {
                  "name": "MONGO_URI",
                  "secretRef": "teacher-mongo-uri"
                },
                {
                  "name": "RESULT_SERVICE_URL",
                  "value": "http://result-service"
                },
                {
                  "name": "STUDENT_SERVICE_URL",
                  "value": "http://student-service"
                },
                {
                  "name": "FORCE_UPDATE",
                  "value": "7"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "course-service",
      "location": "southeastasia",
      "properties": {
        "managedEnvironmentId": "[variables('envId')]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 5003
          },
          "secrets": [
            {
              "name": "course-mongo-uri",
              "value": "[parameters('courseMongoUri')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "course-service",
              "image": "wimukthidocker/course-service:latest",
              "env": [
                {
                  "name": "MONGO_URI",
                  "secretRef": "course-mongo-uri"
                },
                {
                  "name": "FORCE_UPDATE",
                  "value": "6"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "result-service",
      "location": "southeastasia",
      "properties": {
        "managedEnvironmentId": "[variables('envId')]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 5004
          },
          "secrets": [
            {
              "name": "result-mongo-uri",
              "value": "[parameters('resultMongoUri')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "result-service",
              "image": "wimukthidocker/result-service:latest",
              "env": [
                {
                  "name": "MONGO_URI",
                  "secretRef": "result-mongo-uri"
                },
                {
                  "name": "FORCE_UPDATE",
                  "value": "6"
                }
              ]
            }
          ]
        }
      }
    }
  ]
}
